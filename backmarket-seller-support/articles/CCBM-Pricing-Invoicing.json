l</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.7569%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€3.49</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 20.3312%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€4.99</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.2099%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€6.49</span></td></tr><tr style=\"height: 35.0463px;\"><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 24.7561%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">Medium</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.7569%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€4.49</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 20.3312%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€5.99</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.2099%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€6.99</span></td></tr><tr style=\"height: 35.0463px;\"><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 24.7561%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">Large</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.7569%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€5.99</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 20.3312%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€7.99</span></td><td colspan=\"1\" rowspan=\"1\" style=\"border-color: #000000;width: 11.2099%;\"><span style=\"font-family: arial, helvetica, sans-serif;font-size: 13px;\">€9.99</span></td></tr><t