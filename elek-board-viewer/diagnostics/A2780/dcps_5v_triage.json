        {
          "step": 4,
          "action": "Try second port (CF501 for ATC1)",
          "expected": "Current draw"
        }
      ]
    },
    {
      "range": "0.001-0.05A",
      "meaning": "Trickle draw, not progressing.",
      "steps": [
        {
          "step": 1,
          "action": "Check PPBUS_AON at C5704",
          "expected": "Rising voltage"
        },
        {
          "step": 2,
          "action": "Check PP3V8_AON (U5700, page 57)",
          "expected": "3.8V"
        },
        {
          "step": 3,
          "action": "If PP3V8_AON missing, check PPVAON_PWR_EN signal",
          "expected": "High"
        }
      ]
    },
    {
      "range": "0.05-0.3A",
      "meaning": "Partial boot at 5V. PD not negotiating.",
      "steps": [
        {
          "step": 1,
          "action": "Check SPMU/MPMU rails (pages 77-82)",
          "expected": "Present"
        },
        {
          "step": 2,
