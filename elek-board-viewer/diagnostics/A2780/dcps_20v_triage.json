        {
          "step": 3,
          "action": "Check PPBUS_AON",
          "expected": "12V or rising"
        },
        {
          "step": 4,
          "action": "Check PP3V8_AON (U5700, page 57)",
          "expected": "3.8V"
        }
      ]
    },
    {
      "range": "0.05-0.5A",
      "meaning": "Partial boot. Shorted rail or stalled power-up.",
      "steps": [
        {
          "step": 1,
          "action": "Diode mode on PP3V8_AON, PPBUS_AON, PP5V_S2",
          "expected": "Normal readings"
        },
        {
          "step": 2,
          "action": "Check Austringer VR output PP1V8_S1_CLVR_VDDH (page 94-96)",
          "expected": "1.8V"
        },
        {
          "step": 3,
          "action": "Check SPMU/MPMU outputs (pages 77-82)",
          "expected": "All present"
        }
      ]
    },
    {
      "range": "0.5-1.5A",
      "meaning": "Boot attempt stalling. SoC or CLVR domain fault.",
      "steps": [
        {
          "step": 1,
          "action": "Check CLVR0-4 outputs (pages 101-105)",
          "expected": "DVFS voltages present"
        },
        {
          "step": 2,
          "action": "Check PP5V_S2 (UC260, page 122)",
          "expected": "5.15V"
        },
        {
          "step": 3,
          "action": "Thermal camera for hot CLVR/Austringer IC",
          "expected": "No abnormal heat"
        }
      ]
    },
    {
      "range": "1.5-3.5A",
      "meaning": "Normal boot range.",
      "steps": [
        {
          "step": 1,
          "action": "Monitor for full boot completion",
          "expected": "Stable current, display on"
        }
