{
  "board": "A2338",
  "schematic": "820-02020",
  "description": "Complete power delivery chain from USB-C input to SoC power pins. 7 sequential stages. NO MAGSAFE on this model — USB-C only.",
  "WARNING": "A2338 is MBP 13\" M1, NOT MBA M2 (A2681). No MagSafe connector. Charger is B379 (63W) not B405. SoC is M1 (TML R6A0-B09) not M2. Different PMU silicon. Has DFR (Touch Bar) and active fan.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C Input & Initial 5V",
      "description": "USB-C cable supplies 5V default. CD3217B12KE port controllers manage CC signaling and VBUS switching. Two USB-C ports — left rear (debug) and left front.",
      "nodes": [
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC0",
          "voltage": "5V (initial)",
          "ic": "UF400 (CD3217B12KE ATC0)",
          "port": "Left Rear USB-C (debug port)",
          "enable": "Cable insertion detected via CC1/CC2",
          "page": [57, 59]
        },
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC1",
          "voltage": "5V (initial)",
          "ic": "UF500 (CD3217B12KE ATC1)",
          "port": "Left Front USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "page": [58, 59]
        }
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 negotiates USB PD to request 20V from charger adapter.",
      "signals": {
        "cc_lines": ["USBC0_CC1", "USBC0_CC2", "USBC1_CC1", "USBC1_CC2"],
        "charger_aux": "CHGR_AUX_OK",
        "charger_int": "CHGR_INT_L"
      },
      "hv_power_aliases": {
        "description": "HV POWER ALIASES on page 55",
        "ppocin_usbc_aon": "from PPVBUS → fused via FF201 → PPOCIN_USBC_AON → to charger",
        "ppvn_int1_aonn": "PPVN_INT1_AONN — internal charger rail",
        "ppvbus_usbc0": "aliased on page 55"
      },
      "page": [55, 57, 58]
    },
    {
      "stage": 3,
      "name": "Charger → PPBUS_AON",
      "description": "U5200 (Suona B379, 63W) charger IC converts USB-C input to PPBUS_AON. Battery also connects via J5150 solder pads.",
      "nodes": [
        {
          "input": "PPOCIN_USBC_AON",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / follows adapter pre-PD",
          "ic": "U5200 (1S41091 / 353S01525, Suona charger)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT (J5150)",
          "fault": "No PPBUS → charger IC fault / CD3217 not negotiating / battery disconnected",
          "page": [22, 23, 21]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON → PP3V8_AON",
      "description": "U5700 multi-phase buck converts PPBUS_AON to 3.8V always-on rail. 30A ICC MAX. This is the master rail feeding both PMUs and external LDOs.",
      "nodes": [
        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 2-in-1 RS, 30A ICC MAX)",
          "enable": "P3V8AON_PWR_EN (delayed by U5340)",
          "fault": "P3V8AON_FAULT_L (active low)",
          "current_sense": "P3V8AON high bandwidth current sense amplifier (page 94, UN200-UN230)",
          "page": [25, 26, 27]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON branches",
          "description": "PP3V8_AON distributes to VDDMAIN, SPMU, MPMU, external LDOs, WiFi/BT, and more via alias page 100",
          "page": 100
        }
      ]
    },
    {
      "stage": 5,
      "name": "PMU Distribution",
      "description": "PP3V8_AON feeds both SPMU (U7700) and MPMU (U8100). Each PMU generates multiple buck and LDO outputs.",
      "spmu_u7700": {
        "input": "PP3V8_AON",
        "key_outputs": [
          "PP0V764_S1_SRAM (BUCK 5)",
          "PP2V5_AWAKE_NAND (BUCK 6)",
          "PPVDD_ECPU_AWAKE secondary (BUCK 12)",
          "PP1V25_S2 (BUCK 13)",
          "PP1V25_AWAKE_IO (BUCK 13 SW3)",
          "PP0V72_S2_VDD_LOW (LDO 4)",
          "PP0V805_S1_VDD_FIXED (LDO 12)",
          "PP1V2_S2_CIO (LDO 20)",
          "PPVDS5_S2M_CIO (LDO 11)"
        ],
        "page": [28, 29, 30, 31]
      },
      "mpmu_u8100": {
        "input": "PP3V8_AON (VODMAN)",
        "key_outputs": [
          "PPVDD_PCPU_AWAKE (BUCK 0)",
          "PPVDD_GPU_AWAKE (BUCK 1)",
          "PPVDD_SOC_S1 (BUCK 2)",
          "PP1V8_S2 (BUCK 3)",
          "PP1V8_AWAKE (BUCK 3 SW1)",
          "PPVDD_CPU_SRAM_AWAKE (BUCK 7)",
          "PPVDD_DISP_S1 (BUCK 8)",
          "PPVDD_DCS_S1 (BUCK 9)",
          "PPVDD_ECPU_AWAKE (BUCK 11)"
        ],
        "page": [32, 33, 34, 35]
      }
    },
    {
      "stage": 6,
      "name": "External LDOs & Standalone VRs",
      "description": "UC100 and UC120 produce AON LDO rails from PP3V8_AON. UC300 and UC710 produce 5V and 3.3V from PPBUS_AON. Load switches gate subsystems.",
      "regulators": [
        {"input": "PP3V8_AON", "output": "PP3V3_AON", "voltage": "3.3V", "ic": "UC100 (LP5907UVX-3.3)", "enable": "P3V3_AON_EN", "page": 36},
        {"input": "PP3V8_AON", "output": "PP1V8_AON", "voltage": "1.8V", "ic": "UC120 (LP5907UVX-1.8)", "enable": "P1V8_AON_EN", "page": 36},
        {"input": "PPBUS_AON", "output": "PP5V_S2", "voltage": "5.15V", "ic": "UC300 (LT8642S)", "enable": "P5VS2_PWR_EN", "page": 37},
        {"input": "PPBUS_AON", "output": "PP3V3_S2", "voltage": "3.3V", "ic": "UC710 (SN621371)", "enable": "P3V3S2_PWR_EN", "page": 39}
      ],
      "load_switches": [
        {"input": "PP3V3_S2", "output": "PP3V3_S2SW_SNS", "ic": "UC810 (SLG5AP1445V)", "enable": "SENSOR_PWR_EN", "page": 40},
        {"input": "PP3V8_AON", "output": "PP1V8_S2 / PP1V8_S2SW_VDD1", "ic": "UC820 (SLG5AP1445V)", "enable": "PVDD1_PWR_EN", "page": 40}
      ]
    },
    {
      "stage": 7,
      "name": "SoC Power Domains",
      "description": "Final rails reaching SoC U0600 pin groups.",
      "domains": [
        {"domain": "PCPU", "rail": "PPVDD_PCPU_AWAKE", "source": "MPMU BUCK 0", "voltage": "Variable DVFS", "page": 12},
        {"domain": "ECPU", "rail": "PPVDD_ECPU_AWAKE", "source": "MPMU BUCK 11 + SPMU BUCK 12", "voltage": "Variable DVFS", "page": [12, 100]},
        {"domain": "GPU", "rail": "PPVDD_GPU_AWAKE", "source": "MPMU BUCK 1", "voltage": "Variable DVFS", "page": 12},
        {"domain": "CPU_SRAM", "rail": "PPVDD_CPU_SRAM_AWAKE", "source": "MPMU BUCK 7", "voltage": "Variable DVFS", "page": 13},
        {"domain": "SOC S1", "rail": "PPVDD_SOC_S1", "source": "MPMU BUCK 2", "voltage": "Variable", "page": 13},
        {"domain": "DCS S1", "rail": "PPVDD_DCS_S1", "source": "MPMU BUCK 9", "voltage": "Variable", "page": 13},
        {"domain": "DISP S1", "rail": "PPVDD_DISP_S1", "source": "MPMU BUCK 8", "voltage": "Variable", "page": [12, 100]},
        {"domain": "SRAM S1", "rail": "PP0V764_S1_SRAM", "source": "SPMU BUCK 5", "voltage": "0.764V", "page": 13},
        {"domain": "VDD_FIXED", "rail": "PP0V805_S1_VDD_FIXED", "source": "SPMU LDO 12", "voltage": "0.805V", "page": 14},
        {"domain": "VDD_LOW", "rail": "PP0V72_S2_VDD_LOW", "source": "SPMU LDO 4", "voltage": "0.72V", "page": 14},
        {"domain": "VDDOL S1", "rail": "PPVDS_S1_VDDOL", "source": "SPMU BUCK 10", "voltage": "Variable", "page": 100},
        {"domain": "CIO", "rail": "PPVDS5_S2M_CIO / PP1V2_S2_CIO", "source": "SPMU LDO 11 / LDO 20", "page": [14, 101, 102]},
        {"domain": "PLL", "rail": "PP1V2_MAME_PLL", "source": "SPMU BUCK 14 / LDO 8", "voltage": "1.2V", "page": [14, 101]},
        {"domain": "DRAM", "rail": "PPVDS_S2M_DRAM", "source": "SPMU BUCK 4", "voltage": "Variable", "page": [10, 100]},
        {"domain": "IO 1.25V", "rail": "PP1V25_AWAKE_IO", "source": "SPMU BUCK 13 SW3", "voltage": "1.25V", "page": [11, 101]}
      ]
    }
  ]
