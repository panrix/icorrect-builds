        {"name": "PP3V8_AON", "voltage": "3.8V", "source": "U5700 (SVR AON, 30A ICC MAX)"},
        {"name": "PP3V8_AON_VDDMAIN", "voltage": "3.8V", "source": "PP3V8_AON branch (page 101)"},
