{
  "board": "A3114",
  "schematic": "820-03285",
  "WARNING": "MacBook Air 13-inch M3 (X2819/MLB). NOT a Pro, NOT M4. All rails verified against Power Aliases pages 101-104.",
  "description": "All rails grouped by power state (sleep domain). G3H = always present with AC, AON = always on with battery, S2-S0 = progressively more awake.",
  "m3_vs_m2_differences": [
    "WiFi module is Willamette (was Typhoon on M2 A2681)",
    "USB-C retimers are MACAW (UF600/UF650) instead of separate repeater/level-shifter",
    "MagSafe controller is ACE3 (U5900) instead of AAROXA9PA0830",
    "Audio uses 6x TAWANG amplifiers (AMP A-F) instead of fewer on M2",
    "SPMU unused LDOs: 6, 15, 17, 16 (NC). MPMU unused LDOs: 1, 3, 5, 14, 18 (NC)",
    "Leader/Follower PMU terminology used for thermal sensors",
    "PP5V_S2 camera filter uses PP5V_S2 input (LP410)"
  ],
  "domains": {
    "G3H": {
      "description": "Present whenever AC power is connected (pre-charger, pre-battery)",
      "wake_condition": "USB-C or MagSafe cable inserted",
      "rails": [
        {"name": "PPVBUS_USBC0", "voltage": "5V/20V", "source": "UF400 (USB-C PD controller ATC0)"},
        {"name": "PPVBUS_USBC1", "voltage": "5V/20V", "source": "UF500 (USB-C PD controller ATC1)"},
        {"name": "PPDCIN_USBC_AON", "voltage": "5V-20V", "source": "USB-C DCIN alias (page 101)"},
        {"name": "PPCON_ACNSW", "voltage": "~5-20V", "source": "Charger input path"},
        {"name": "PPVBUS_USBC5", "voltage": "5V-20V", "source": "MagSafe via ACE3 (U5900)"}
      ]
    },
    "AON": {
