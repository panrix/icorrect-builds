          {"buck": "BUCK 13", "output": "PP1V25_S2", "voltage": "1.25V", "state": "S2"},
          {"buck": "BUCK 13 SW3", "output": "PP1V25_AWAKE_3D", "voltage": "1.25V", "state": "AWAKE"}
        ],
        "ldos": [
          {"ldo": "LDO 1", "output": "NC", "state": "NC", "max_ma": 300},
          {"ldo": "LDO 2", "output": "PP3V_AON", "voltage": "3.0V", "state": "AON", "max_ma": 50},
          {"ldo": "LDO 3", "output": "NC", "state": "NC", "max_ma": 600},
          {"ldo": "LDO 5", "output": "NC", "state": "NC", "max_ma": 250},
          {"ldo": "LDO 7", "output": "PP3V3_S2_LDO", "voltage": "3.3V", "state": "S2", "max_ma": 250},
          {"ldo": "LDO 8", "output": "PP1V2_AWAKE_PLL", "voltage": "1.2V", "state": "AWAKE", "max_ma": 730},
