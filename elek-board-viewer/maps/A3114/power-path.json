          {"buck": "BUCK 10", "output": "PP0V5_S1_VDDOL", "voltage": "0.5V", "state": "S1"},
          {"buck": "BUCK 12", "output": "PPVDD_AWAKE_PCPU_2", "voltage": "Variable", "state": "AWAKE"},
          {"buck": "BUCK 12 SW6/7", "output": "PP3V8_AWAKE_NAND_VDD", "voltage": "3.8V", "state": "AWAKE"},
          {"buck": "BUCK 13 SW5", "output": "PP1V25_AWAKE_NAND_VCC5", "voltage": "1.25V", "state": "AWAKE"},
          {"buck": "BUCK 3 SW4", "output": "PP1V8_AWAKE_SPMU_GP10", "voltage": "1.8V", "state": "AWAKE"},
