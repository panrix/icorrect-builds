        ],
        "ldos": [
          {"ldo": "LDO 4", "output": "PP0V72_S2_VDD_LOW", "voltage": "0.72V", "state": "S2", "max_ma": 300},
          {"ldo": "LDO 6", "output": "NC", "state": "NC", "max_ma": 50},
          {"ldo": "LDO 9", "output": "PP1V8_AON_SPMU", "voltage": "1.8V", "state": "AON", "max_ma": 10},
          {"ldo": "LDO 9B", "output": "PP1V2_AON_SPMU", "voltage": "1.2V", "state": "AON", "max_ma": 10},
          {"ldo": "LDO 12", "output": "PP0V78_S1_VDD_FIXED", "voltage": "0.78V", "state": "S1", "max_ma": 850},
          {"ldo": "LDO 15", "output": "NC", "state": "NC"},
          {"ldo": "LDO 17", "output": "NC", "state": "NC", "max_ma": 250},
          {"ldo": "LDO 18", "output": "NC", "state": "NC", "max_ma": 250},
          {"ldo": "LDOINT", "output": "PP1V5_LDOINT_SPMU", "voltage": "1.5V", "state": "AON", "max_ma": 150}
        ],
        "boost": {"output": "PP5V_SPMU_BSTLQ", "voltage": "5.0V", "state": "AON"},
        "switches": [
          {"sw": "VSW4", "output": "PP1V8_AWAKE_SPMU_GP10", "max_ma": 200, "mohm": 125},
          {"sw": "VSW5", "output": "PP1V25_AWAKE_NAND_VCC5", "max_ma": 900, "mohm": 23},
          {"sw": "VSW6", "output": "PP3V8_AWAKE_NAND_VDD", "max_ma": 150, "mohm": 23},
          {"sw": "VSW7", "output": "PP3V8_AWAKE_NAND_VDD (tied to SW6)", "max_ma": 920, "mohm": 23}
        ],
        "page": [38, 39, 40, 41]
      },
