          "frequency": "1.3MHz",
          "page": [53]
        }
      ]
    },
    {
      "stage": 7,
      "name": "SoC Power Domains",
      "description": "Final rails reaching SoC U6000 pin groups.",
      "domains": [
        {"domain": "PCPU", "rail": "PPVDD_AWAKE_PCPU", "source": "MPMU BUCK 0", "page": 18},
        {"domain": "ECPU", "rail": "PPVDD_AWAKE_ECPU", "source": "MPMU BUCK 11", "page": 19},
