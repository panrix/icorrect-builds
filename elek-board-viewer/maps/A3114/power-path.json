{
  "board": "A3114",
  "schematic": "820-03285",
  "WARNING": "MacBook Air 13-inch M3 (X2819/MLB). NOT Pro, NOT M4.",
  "description": "Complete power delivery chain from USB-C/MagSafe input to SoC power pins. 7 sequential stages.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C Input & Initial 5V",
      "description": "USB-C connector supplies 5V default. Port controllers manage CC signaling and VBUS switching.",
      "nodes": [
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC0",
          "voltage": "5V (initial)",
          "ic": "UF400 (ATC0 Port Controller)",
          "port": "Left Rear USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication -> cable/connector fault",
          "test_point": "CF400/CF401 (PPVBUS_USBC0 decoupling)",
          "page": [64, 69]
        },
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC1",
          "voltage": "5V (initial)",
          "ic": "UF500 (ATC1 Port Controller)",
          "port": "Left Front USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication -> cable/connector fault",
          "test_point": "CF501 (PPVBUS_USBC1 decoupling)",
          "page": [64, 70]
        },
        {
          "input": "MagSafe cable",
          "output": "PPVBUS_USBC5",
          "voltage": "5V -> 20V",
          "ic": "U5900 (ACE3 MagSafe Port Controller, 338S01614)",
          "port": "J5401 MagSafe",
          "enable": "Magnet detection -> D5401/D5402/D5403 ESD circuit",
          "fuse": "F5600 (CONNECTION TO DCIN, 4A-32V, CRITICAL)",
          "page": [32, 33, 34]
        }
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "Port controllers negotiate USB PD to request 20V from charger adapter.",
      "page": [30, 69, 70]
    },
    {
      "stage": 3,
      "name": "Charger -> PPBUS_AON",
      "description": "Charger IC converts USB-C/MagSafe input to PPBUS_AON. Battery also connects to PPBUS_AON.",
      "nodes": [
        {
          "input": "PPDCIN_USBC_AON / PPCON_ACNSW",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter)",
          "ic": "Charger IC (page 30 area)",
          "enable": "CHGR_AUX_OK (page 31), BMU SYS_DETECT (J5150, page 29)",
          "fault": "No PPBUS -> charger IC fault, port controller not negotiating, or battery disconnected",
          "test_point": "C5704 -> expect 12V",
          "page": [29, 30, 31]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON -> PP3V8_AON",
      "description": "U5700 multi-phase buck converts PPBUS_AON down to 3.8V always-on rail. Single most important rail.",
      "nodes": [
        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 30A ICC MAX, APN 351002645)",
          "enable": "P3V8AON_PWR_EN",
          "fault": "P3V8AON_FAULT_L (active low)",
          "current_sense": "U5910 (MAX41033ANT+), U5950",
          "page": [35, 36, 37]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_VDDMAIN",
          "voltage": "3.8V",
          "ic": "Distribution (branch of PP3V8_AON)",
          "page": [101]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_WLBT",
          "voltage": "3.8V",
          "ic": "Distribution to WiFi/BT Willamette module",
          "page": [75, 101]
        }
      ]
    },
    {
      "stage": 5,
      "name": "PMU Distribution",
      "description": "PP3V8_AON feeds both SPMU (U7700) and MPMU (U8100). Each PMU generates multiple buck and LDO outputs.",
      "spmu_u7700": {
        "input": "PP3V8_AON",
        "omit_table": "998-23585",
