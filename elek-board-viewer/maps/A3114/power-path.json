          {"buck": "BUCK 1", "output": "PPVDD_AWAKE_GPU", "voltage": "Variable DVFS", "state": "AWAKE"},
          {"buck": "BUCK 2", "output": "PPVDD_S1_SOC", "voltage": "Variable", "state": "S1"},
          {"buck": "BUCK 3", "output": "PP1V8_S2", "voltage": "1.8V", "state": "S2"},
          {"buck": "BUCK 3 SW1", "output": "PP1V8_AWAKE", "voltage": "1.8V", "state": "AWAKE"},
          {"buck": "BUCK 3 SW2", "output": "PP1V8_S2SM_DPG", "voltage": "1.8V", "state": "S2"},
          {"buck": "BUCK 4", "output": "PP1V85_S2SM_VDDQ5", "voltage": "1.85V", "state": "S2"},
          {"buck": "BUCK 7", "output": "PPVDD_AWAKE_CPU_SRAM", "voltage": "Variable DVFS", "state": "AWAKE"},
          {"buck": "BUCK 9", "output": "PPVDD_S1_DCS", "voltage": "Variable", "state": "S1"},
