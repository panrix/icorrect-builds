{
  "board": "A2681",
  "schematic": "820-02536",
  "description": "Complete power delivery chain from USB-C/MagSafe input to SoC power pins. 7 sequential stages.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C Input & Initial 5V",
      "description": "USB-C connector supplies 5V default. CD3217 port controllers manage CC signaling and VBUS switching.",
      "nodes": [
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC0",
          "voltage": "5V (initial)",
          "ic": "UF400 (CD3217 ATC0)",
          "port": "Left Rear USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication → cable/connector fault",
          "test_point": "CF400/CF401 (PPVBUS_USBC0 decoupling)",
          "page": [58, 63]
        },
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC1",
          "voltage": "5V (initial)",
          "ic": "UF500 (CD3217 ATC1)",
          "port": "Left Front USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication → cable/connector fault",
          "test_point": "CF501 (PPVBUS_USBC1 decoupling)",
          "page": [58, 64]
        },
        {
          "input": "MagSafe cable",
          "output": "MagSafe VBUS (via 20V aliases)",
          "voltage": "5V → 20V",
          "ic": "MagSafe Port Controller (UPC5 area, AAROXA9PA0830)",
          "port": "J5401 MagSafe",
          "enable": "Magnet detection → Q5401 MOSFET pair enables",
          "page": [27, 28, 29]
        }
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 reads firmware from SPI ROM via CC lines, negotiates USB PD to request 20V from charger adapter. Based on M1/M2 power-on reference: this happens AFTER initial SoC hard start at 5V.",
      "sequence": [
        "1. CD3217 internal MOSFET passes 5V → PPVL_APCL_ACMON",
        "2. SoC powers up at 5V (hard start)",
        "3. M2 SoC sends command to CD3217",
        "4. CD3217 reads ROM info via USBC0_CC1/USBC0_CC2",
        "5. CD3217 sends PD Source_Capabilities request via CC line",
        "6. Charger adapter responds with 20V capability",
        "7. PPVBUS_USBC0 transitions from 5V → 20V",
        "8. Protection isolation passes → PPBUS_AON established at battery voltage (~12.6V)"
      ],
      "signals": {
        "cc_lines": ["USBC0_CC1", "USBC0_CC2", "USBC1_CC1", "USBC1_CC2"],
        "spi_rom": ["SPI_UPC0 (ATC0 firmware)", "SPI_UPC1 (ATC1 firmware)"],
        "charger_aux": "CHGR_AUX_OK (indicates charger ready)",
        "charger_int": "CHGR_INT_L (charger interrupt, active low)"
      },
      "page": [25, 26, 63, 64, 68]
    },
    {
      "stage": 3,
      "name": "Charger → PPBUS_AON",
      "description": "Charger IC converts USB-C/MagSafe input to PPBUS_AON. Battery also connects to PPBUS_AON. This is the main system power bus.",
      "nodes": [
        {
          "input": "PPVL_APCL_ACMON / PPCON_ACNSW",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter, before regulation)",
          "ic": "U5200 area (Charger IC)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT (J5150 gasket)",
          "fault": "No PPBUS → charger IC fault, CD3217 not negotiating, or battery disconnected",
          "test_point": "C5704 → expect 12V",
          "test_point_note": "From Ricky's diagnostic: Step 1 — if missing, fault in charging circuit / CD3217 / U5200",
          "page": [25, 26, 24]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON → PP3V8_AON",
      "description": "U5700 multi-phase buck converts PPBUS_AON down to 3.8V always-on rail. This is the single most important rail — it powers both PMUs.",
      "nodes": [
        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 30A ICC MAX)",
          "enable": "PPVAON_PWR_EN",
          "fault": "PPVAON_FAULT_L (active low)",
          "current_sense": "U5910 (PP3V8_AON current sense via PPVAON_ISNS_P/N)",
          "test_point": "C8450 → expect 3.8V",
          "test_point_note": "From Ricky's diagnostic: Step 2 — if missing, fault in U5700 / Q5800",
          "page": [30, 31, 32]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_VDDMAIN",
          "voltage": "3.8V",
          "ic": "Distribution (branch of PP3V8_AON)",
          "description": "VDDMAIN distribution — known fault: shorts on C7705",
          "test_point": "C7705 → expect 3.8V (if shorted, draws excessive current)",
          "page": [92]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_WLBT",
          "voltage": "3.8V",
          "ic": "Distribution to WiFi/BT Typhoon module",
          "page": [69, 92]
        }
      ]
    },
    {
      "stage": 5,
      "name": "PMU Distribution",
      "description": "PP3V8_AON feeds both SPMU (U7700) and MPMU (U8100). Each PMU generates multiple buck and LDO outputs for SoC power domains and peripherals.",
      "spmu_u7700": {
        "input": "PP3V8_AON",
        "bucks": [
          {"buck": "BUCK 5", "output": "PP0V75_S1_SRAM", "voltage": "0.75V", "state": "S1", "load": "SoC SRAM retention + PP0V75_S1_SOC alias"},
          {"buck": "BUCK 6", "output": "PP1V25_MAME_NAND_VCC", "voltage": "1.25V", "state": "AWAKE", "load": "NAND flash VCC"},
          {"buck": "BUCK 8", "output": "PP0V5_S1_ESTP", "voltage": "0.5V", "state": "S1", "load": "SoC ESTP domain"},
          {"buck": "BUCK 10", "output": "PP0V5_S1_VDDOL", "voltage": "0.5V", "state": "S1", "load": "SoC VDDOL"},
          {"buck": "BUCK 12", "output": "PPVDD_MAME_PCPU_2", "voltage": "Variable", "state": "AWAKE", "load": "SoC PCPU secondary phase"},
          {"buck": "BUCK 12 SW6/7", "output": "PP3V8_MAME_NAND_VDDL", "voltage": "3.8V", "state": "AWAKE", "load": "NAND VDDL"},
          {"buck": "BUCK 13 SW5", "output": "PP1V25_MAME_NAND_VCC5", "voltage": "1.25V", "state": "AWAKE", "load": "NAND VCC2/VCC5"},
          {"buck": "BUCK 3 SW4", "output": "PP1V8_MAME_SPMU_GFS5", "voltage": "1.8V", "state": "AWAKE", "load": "SPMU GFS5"},
          {"buck": "BUCK 14", "output": "PP1V12_S2M_AMPH", "voltage": "1.12V", "state": "S2", "load": "Memory controller AMPH"}
        ],
        "ldos": [
          {"ldo": "LDO 4", "output": "PP0V72_S2_VDD_LOW", "voltage": "0.72V", "state": "S2", "load": "SoC VDD_LOW domain"},
          {"ldo": "LDO 9", "output": "PP1V8_AON_SPMU", "voltage": "1.8V", "state": "AON", "load": "Always-on 1.8V from SPMU"},
          {"ldo": "LDO 9B", "output": "PP1V2_AON_SPMU", "voltage": "1.2V", "state": "AON", "load": "Always-on 1.2V from SPMU"},
          {"ldo": "LDO 12", "output": "PP0V75_S1_VDD_FIXED", "voltage": "0.75V", "state": "S1", "load": "SoC VDD_FIXED domain"},
          {"ldo": "LDO 17", "output": "PP3V3_S2M_DPG", "voltage": "3.3V", "state": "S2", "load": "Trackpad"},
          {"ldo": "LDO 18", "output": "PP3V3_S2SM_270", "voltage": "3.3V", "state": "S2", "load": "Peripheral"}
        ],
        "boost": {"output": "PP3V8_SPMU_BSTLQ", "voltage": "3.8V", "state": "AWAKE"},
        "page": [33, 34, 35, 36]
      },
      "mpmu_u8100": {
        "input": "PP3V8_AON (VODMAN)",
        "bucks": [
          {"buck": "BUCK 0", "output": "PPVDD_MAME_PCPU", "voltage": "Variable DVFS", "state": "AWAKE", "load": "SoC Performance CPU"},
          {"buck": "BUCK 1", "output": "PPVDD_MAME_GPU", "voltage": "Variable DVFS", "state": "AWAKE", "load": "SoC GPU"},
          {"buck": "BUCK 2", "output": "PP0V5_S1_SOC", "voltage": "0.5V", "state": "S1", "load": "SoC 0.5V domain"},
          {"buck": "BUCK 3", "output": "PP1V21_S2", "voltage": "1.21V", "state": "S2", "load": "SoC VDD10/VDD_LOW input"},
          {"buck": "BUCK 3 SW1", "output": "PP1V8_MAME (= PP1V8_S2)", "voltage": "1.8V", "state": "S2/AWAKE", "load": "Motion sensor, display sequencer, level shifters"},
          {"buck": "BUCK 4", "output": "PP1V85_S2M_VDDQ5", "voltage": "1.85V", "state": "S2", "load": "Memory VDDQ5"},
          {"buck": "BUCK 7", "output": "PPVDD_MAME_CPU_SRAM", "voltage": "Variable DVFS", "state": "AWAKE", "load": "SoC SRAM"},
          {"buck": "BUCK 9", "output": "PP0V5_S1_DCS", "voltage": "0.5V", "state": "S1", "load": "SoC DCS"},
          {"buck": "BUCK 11", "output": "PPVDD_MAME_ECPU", "voltage": "Variable DVFS", "state": "AWAKE", "load": "SoC Efficiency CPU"},
          {"buck": "BUCK 13", "output": "PP1V25_S2", "voltage": "1.25V", "state": "S2", "load": "USB-C controllers, level shifters"},
          {"buck": "BUCK 13 SW3", "output": "PP1V25_MAME_3D", "voltage": "1.25V", "state": "AWAKE", "load": "SoC 3D domain, SPI ROM"}
        ],
        "ldos": [
          {"ldo": "LDO 1", "output": "PP1V8_MAME", "voltage": "1.8V", "state": "AWAKE", "load": "1.8V awake peripherals"},
          {"ldo": "LDO 5", "output": "PP3V_S2_LDO (= PP3V_AON)", "voltage": "3.0V", "state": "S2/AON", "load": "PBUS sense, charger support, I2C pull-ups"},
          {"ldo": "LDO 7", "output": "PP3V3_S2_LDO", "voltage": "3.3V", "state": "S2", "load": "3.3V peripherals"},
          {"ldo": "LDO 8", "output": "PP1V12_MAME_PLL", "voltage": "1.12V", "state": "AWAKE", "load": "SoC PLL"},
          {"ldo": "LDO 9", "output": "PP1V8_AON_MPMU", "voltage": "1.8V", "state": "AON", "load": "Load switch enables, GPIO LVCMOS", "test_point": "C8320 → expect 1.8V"},
          {"ldo": "LDO 9B", "output": "PP1V2_AON_MPMU", "voltage": "1.2V", "state": "AON", "load": "Always-on 1.2V", "test_point": "C8360 → expect 1.2V"},
          {"ldo": "LDO 10", "output": "PPVDS5_S2SM_CIO (= PP0V855_USBC_CIO)", "voltage": "0.855V", "state": "S2", "load": "SoC CIO / USB-C CIO"},
          {"ldo": "LDO 11", "output": "PP0V83_S1_STOP", "voltage": "0.83V", "state": "S1", "load": "SoC STOP domain"},
          {"ldo": "LDO 13", "output": "PP3V3_S2M_SNR", "voltage": "3.3V", "state": "S2", "load": "Sensor rail", "test_point": "C8330 → expect 3.3V"},
          {"ldo": "LDO 14", "output": "PP3V3_S2SM_CIO", "voltage": "3.3V", "state": "S2", "load": "CIO 3.3V domain"},
          {"ldo": "LDOINT", "output": "PP1V05_LDOINT_MPMU", "voltage": "1.05V", "state": "AON", "load": "MPMU internal + LDO RTC (shorted for portables)"}
        ],
        "boost": {"output": "PP3V8_MAME_BSTLQ", "voltage": "3.8V", "state": "AWAKE"},
        "control_signals": {
          "ready": "PMU_ACTIVE_READY",
          "fault": "PMU_FAULT_INT_L",
          "reset": "PMU_RESET_L",
          "force_dfu": "SOC_FORCE_DFU",
          "charger_reset": "CHGR_RST_2N_R (via U8740)"
        },
        "test_points": {
          "C8320": {"rail": "PP1V8_AON_MPMU (LDO 9)", "voltage": "1.8V"},
          "C8330": {"rail": "PP3V3_S2M_SNR (LDO 13)", "voltage": "3.3V"},
          "C83A0": {"rail": "PP3V3 (LDO variant)", "voltage": "3.3V"},
          "C8360": {"rail": "PP1V2_AON_MPMU (LDO 9B)", "voltage": "1.2V"},
          "C8380": {"rail": "MPMU LDO 20 (~PP1V5_xxx)", "voltage": "1.5V"}
        },
        "page": [37, 38, 39, 40, 41, 42, 43]
      }
    },
    {
