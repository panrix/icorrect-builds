          "current_limit": "400mA",
          "rc_delay": "25.5ms",
          "page": 40
        },
        {
          "input": "PP5V_S2",
          "output": "PP5V_S2SW_IPD",
          "voltage": "5V",
          "enable": "MPMU GPIO6 (PP1V8_AON)",
          "current_limit": "1.35A",
          "rc_delay": "4.7ms",
          "page": 40
        },
        {
          "input": "PPBUS_AON",
          "output": "PPBUS_AONSW_IPD",
          "voltage": "12.6V/20V",
          "enable": "Self Controlled (3.13-5.93V)",
          "current_limit": "3A",
          "page": 40
        }
      ]
    },
    {
      "stage": 7,
      "name": "SoC Power Domains",
      "description": "Final rails reaching SoC U6000 (M1 T8103) pin groups. Each domain has dedicated decoupling.",
      "domains": [
