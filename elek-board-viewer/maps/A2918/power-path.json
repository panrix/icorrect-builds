          "enable": "PPVAON_PWR_EN (delayed by D5340/R5340/R5341 circuit on page 30)",
          "fault": "PPVAON_FAULT_L (active low)",
          "current_sense": "PP3V8_AON current sense amplifier (IMVR, page 57)",
          "test_point": "TPU665 (PP3V8_AON, FCT page 113)",
          "page": [34, 35, 36]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_VDDMAIN",
          "voltage": "3.8V",
          "ic": "Distribution (branch of PP3V8_AON)",
          "description": "VDDMAIN distribution",
          "page": [125]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_WLBT_ISNS",
          "voltage": "3.8V",
          "ic": "Distribution to WiFi/BT Willamette module with sense",
          "page": [87, 129]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_HDMI_ISNS",
          "voltage": "3.8V",
          "ic": "Distribution to HDMI Cobra with sense",
          "page": [80, 129]
        }
      ]
    },
