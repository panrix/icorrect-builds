{
  "board": "A2918",
  "schematic": "820-02757",
  "description": "Complete power delivery chain from USB-C/MagSafe input to SoC power pins. 7 sequential stages. M3 MacBook Pro 14\" with HDMI and SD card Pro features.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C Input & Initial 5V",
      "description": "USB-C connector supplies 5V default. CD3217 port controllers manage CC signaling and VBUS switching.",
      "components": ["UF400", "UF500", "UPC5", "CF401", "CF503"],
      "input_rails": ["USB-C cable 5V"],
      "output_rails": ["PPVBUS_USBC0", "PPVBUS_USBC1", "PPVBUS_USBC5"],
      "page": [31, 32, 33, 66, 71, 72],
      "nodes": [
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC0",
          "voltage": "5V (initial)",
          "ic": "UF400 (CD3217 ATC0, COLTRANE_CRAKE)",
          "port": "Left Rear USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication → cable/connector fault",
          "test_point": "CF401 (PPVBUS_USBC0)",
          "page": [66, 71]
        },
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC1",
          "voltage": "5V (initial)",
          "ic": "UF500 (CD3217 ATC1)",
          "port": "Left Front USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "test_point": "CF503 (PPVBUS_USBC1)",
          "page": [66, 72]
        },
        {
          "input": "MagSafe cable",
          "output": "PPVBUS_USBC5",
          "voltage": "5V → 20V",
          "ic": "UPC5 (CD3217/CD3218, MagSafe port controller)",
          "port": "J5401 MagSafe",
          "enable": "Magnet detection → Q5401 MOSFET pair enables",
          "page": [31, 32, 33]
        }
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 reads firmware from SPI ROM, negotiates USB PD to request 20V from charger adapter.",
      "components": ["UF400", "UF500", "UPC5"],
      "input_rails": ["PPVBUS_USBC0", "PPVBUS_USBC1"],
      "output_rails": ["PPDCIN_USBC_AON"],
      "page": [29, 30, 71, 72],
      "sequence": [
        "1. CD3217 internal MOSFET passes 5V",
        "2. SoC powers up at 5V (hard start)",
        "3. M3 SoC sends command to CD3217",
        "4. CD3217 reads ROM info via SPI_UPC0",
        "5. CD3217 sends PD Source_Capabilities request via CC line",
        "6. Charger adapter responds with 20V capability",
        "7. PPVBUS_USBC0 transitions from 5V → 20V",
        "8. PPDCIN_USBC_AON established, charger IC gets full input"
      ],
      "signals": {
        "cc_lines": ["USBC0_CC1", "USBC0_CC2", "USBC1_CC1", "USBC1_CC2"],
        "spi_rom": ["SPI_UPC0 (ATC0 firmware)", "SPI_UPC1 (ATC1 firmware)"],
        "charger_aux": "CHGR_AUX_OK (indicates charger ready, page 30)",
        "charger_int": "CHGR_INT_L (charger interrupt, active low, page 30)"
      },
      "page": [29, 30, 71, 72]
    },
    {
      "stage": 3,
      "name": "Charger → PPBUS_AON",
      "description": "U5200 (RAA009063-6) converts USB-C/MagSafe input to PPBUS_AON. Battery also connects to PPBUS_AON via J5151.",
      "components": ["U5200", "J5151", "F5200", "F5201", "L5200"],
      "input_rails": ["PPDCIN_USBC_AON", "PPVBUS_USBC5"],
      "output_rails": ["PPBUS_AON"],
      "page": [28, 29],
      "nodes": [
        {
          "input": "PPDCIN_USBC_AON / PPVBUS_USBC5",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter, before regulation)",
          "ic": "U5200 (RAA009063-6)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT (J5151 gasket via D5130/U5150)",
          "fault": "No PPBUS → charger IC fault, CD3217 not negotiating, or battery disconnected",
          "test_point": "TPU651 (PPBUS_AON, FCT page 113)",
          "page": [28, 29]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON → PP3V8_AON",
      "description": "U5700 (RAA22505FSC-BOMS) 3-phase buck converts PPBUS_AON down to 3.8V always-on rail. This is the single most important rail — it powers both PMUs.",
      "components": ["U5700"],
      "input_rails": ["PPBUS_AON"],
      "output_rails": ["PP3V8_AON", "PP3V8_AON_VDDMAIN", "PP3V8_AON_WLBT_ISNS", "PP3V8_AON_HDMI_ISNS"],
      "page": [34, 35, 36],
