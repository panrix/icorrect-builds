{
  "board": "A2918",
  "schematic": "820-02757",
  "description": "All rails grouped by power state (sleep domain). G3H = always present with AC, AON = always on with battery, S2-S0 = progressively more awake. M3 MacBook Pro 14\" with HDMI/SD Pro features.",
  "domains": {
    "G3H": {
      "description": "Present whenever AC power is connected (pre-charger, pre-battery)",
      "wake_condition": "USB-C or MagSafe cable inserted",
      "rails": [
        {"name": "PPVBUS_USBC0", "voltage": "5V/20V", "source": "UF400 (CD3217)"},
        {"name": "PPVBUS_USBC1", "voltage": "5V/20V", "source": "UF500 (CD3217)"},
        {"name": "PPVBUS_USBC5", "voltage": "5V/20V", "source": "UPC5 (MagSafe CD3217)"},
        {"name": "PPDCIN_USBC_AON", "voltage": "~5-20V", "source": "USB-C DCIN path"}
      ]
    },
    "AON": {
      "description": "Always on when battery or charger connected. Stays up in all sleep states.",
      "wake_condition": "PPBUS_AON present (battery connected or charger active)",
      "enable_signals": ["PPVAON_PWR_EN (for U5700)", "BMU SYS_DETECT (J5151 gasket)"],
      "rails": [
        {"name": "PPBUS_AON", "voltage": "12.6V", "source": "Charger IC / Battery"},
        {"name": "PPVBAT_AON", "voltage": "12.6V", "source": "Battery via charger"},
        {"name": "PP3V8_AON", "voltage": "3.8V", "source": "U5700 (SVR AON, 30A)"},
        {"name": "PP3V8_AON_VDDMAIN", "voltage": "3.8V", "source": "PP3V8_AON branch"},
        {"name": "PP3V8_AON_WLBT_1SNS", "voltage": "3.8V", "source": "PP3V8_AON via sense"},
        {"name": "PP3V8_AON_SPKAMP_LEFT_1SNS", "voltage": "3.8V", "source": "PP3V8_AON via sense"},
        {"name": "PP3V8_AON_SPKAMP_RIGHT_1SNS", "voltage": "3.8V", "source": "PP3V8_AON via sense"},
        {"name": "PP3V8_AON_HDMI_1SNS", "voltage": "3.8V", "source": "PP3V8_AON via sense"},
        {"name": "PP1V8_AON_MPMU", "voltage": "1.8V", "source": "MPMU LDO 9"},
        {"name": "PP1V8_AON_SPMU", "voltage": "1.8V", "source": "SPMU LDO 9"},
        {"name": "PP1V2_AON_MPMU", "voltage": "1.2V", "source": "MPMU LDO 9B"},
        {"name": "PP1V2_AON_SPMU", "voltage": "1.2V", "source": "SPMU LDO 9B"},
        {"name": "PP1V05_LDOINT_MPMU", "voltage": "1.05V", "source": "MPMU LDOINT"},
        {"name": "PP1V05_LDOINT_SPMU", "voltage": "1.05V", "source": "SPMU LDOINT"},
        {"name": "PPBUS_AON_BKLT_1SNS", "voltage": "12.6V", "source": "Load switch from PPBUS_AON"}
      ]
    },
    "S2": {
      "description": "System sleep / standby. Memory retention active. Most peripherals off.",
      "wake_condition": "PMU enable signals from AON domain.",
      "enable_signals": ["PPV5S2TS_PWR_EN (for UC260)", "PV001_PWR_EN (for UC840)"],
      "rails": [
        {"name": "PP5V_S2", "voltage": "5.14V/5.232V", "source": "UC260 (TPS62130)"},
        {"name": "PP3V3_S2_LDO", "voltage": "3.3V", "source": "MPMU LDO 7"},
        {"name": "PP1V25_S2", "voltage": "1.25V", "source": "MPMU BUCK 13"},
        {"name": "PP1V21_S2", "voltage": "1.21V", "source": "MPMU BUCK 3"},
        {"name": "PP1V8_S2", "voltage": "1.8V", "source": "MPMU BUCK 3 SW1 (PP1V8_MAME alias)"},
        {"name": "PP1V12_S2M_AMPH", "voltage": "1.12V", "source": "SPMU BUCK 14"},
        {"name": "PP1V85_S2M_VDDQ5", "voltage": "1.85V", "source": "MPMU BUCK 4"},
        {"name": "PPVDD_S2M_VDDQ", "voltage": "Variable", "source": "MPMU BUCK 10"},
        {"name": "PP0V72_S2_VDD_LOW", "voltage": "0.72V", "source": "SPMU LDO 4"},
        {"name": "PPVDS5_S2SM_CIO", "voltage": "0.855V", "source": "MPMU LDO 10"},
        {"name": "PP3V3_S2M_SNR", "voltage": "3.3V", "source": "MPMU LDO 13"},
        {"name": "PP3V3_S2M_S60", "voltage": "3.3V", "source": "MPMU LDO 14"},
        {"name": "PP0V75_S2_VDD_FIXED", "voltage": "0.75V", "source": "SPMU LDO 12"},
        {"name": "PP1V2_S2_C10", "voltage": "1.2V", "source": "MPMU LDO 20"},
        {"name": "PP5V_S2_UPC", "voltage": "5.23V", "source": "LF800"},
        {"name": "PP1V8_S2SW", "voltage": "1.8V", "source": "UC840 load switch"},
        {"name": "PP1V2_USBC_VDDIO", "voltage": "1.2V", "source": "UF900"},
        {"name": "PP3V3_S2_HOLD_IPD", "voltage": "3.3V", "source": "Load switch"},
        {"name": "PP1V8_S2_WLBT_1SNS", "voltage": "1.8V", "source": "PP1V8_S2 via sense"}
      ]
    },
    "S1": {
      "description": "Light sleep. Core SoC domains retained at low voltage.",
      "wake_condition": "S2 domain active + SoC sleep state controller asserts S1 enables",
      "rails": [
        {"name": "PP0V75_S1_SRAM", "voltage": "0.75V", "source": "SPMU BUCK 5"},
        {"name": "PP0V5_S1_SOC", "voltage": "0.5V", "source": "MPMU BUCK 2"},
        {"name": "PP0V5_S1_DCS", "voltage": "0.5V", "source": "MPMU BUCK 9"},
        {"name": "PP0V5_S1_ESTP", "voltage": "0.5V", "source": "SPMU BUCK 8"},
        {"name": "PP0V5_S1_VDDOL", "voltage": "0.5V", "source": "SPMU BUCK 10"},
        {"name": "PP0V83_S1_STOP", "voltage": "0.83V", "source": "MPMU LDO 11"},
        {"name": "PPVDD_USBC_FIXED", "voltage": "0.805V", "source": "UF930"}
      ]
    },
    "S0_AWAKE": {
      "description": "Fully awake. SoC running, display on, all dynamic domains active.",
      "wake_condition": "PMU_ACTIVE_READY asserted. All S2/S1 rails stable.",
      "signal": "PMU_ACTIVE_READY",
      "rails": [
        {"name": "PPVDD_MAME_PCPU", "voltage": "Variable DVFS", "source": "MPMU BUCK 0"},
        {"name": "PPVDD_MAME_PCPU_2", "voltage": "Variable DVFS", "source": "SPMU BUCK 12"},
        {"name": "PPVDD_MAME_ECPU", "voltage": "Variable DVFS", "source": "MPMU BUCK 11"},
        {"name": "PPVDD_MAME_GPU", "voltage": "Variable DVFS", "source": "MPMU BUCK 1"},
        {"name": "PPVDD_MAME_CPU_SRAM", "voltage": "Variable DVFS", "source": "MPMU BUCK 7"},
        {"name": "PPVDD_MAME_CPU_SRAM_2", "voltage": "Variable DVFS", "source": "SPMU BUCK 7"},
        {"name": "PP1V25_MAME_3D", "voltage": "1.25V", "source": "MPMU BUCK 13 SW3"},
        {"name": "PP1V8_MAME", "voltage": "1.8V", "source": "MPMU BUCK 3 SW1"},
        {"name": "PP1V2_MAME_PLL", "voltage": "1.2V", "source": "MPMU LDO 8"},
        {"name": "PP3V8_MAME", "voltage": "3.8V", "source": "PP3V8_AON gated"},
        {"name": "PP3V8_MAME_BSTLQ", "voltage": "3.8V", "source": "MPMU VDD BOOST"},
        {"name": "PP3V8_SPMU_BSTLQ", "voltage": "3.8V", "source": "SPMU VDD BOOST"},
        {"name": "PP1V25_MAME_NAND_VCC", "voltage": "1.25V", "source": "SPMU BUCK 6"},
        {"name": "PP1V25_MAME_NAND_VCC5", "voltage": "1.25V", "source": "SPMU BUCK 13 SW5"},
        {"name": "PP3V8_MAME_NAND_VDDL", "voltage": "3.8V", "source": "SPMU BUCK 12 SW6/7"},
        {"name": "PP0V95_MAME2W_DFCHM1", "voltage": "0.95V", "source": "UH908 (HDMI buck)"},
        {"name": "PP3V3_MAME_S60", "voltage": "3.3V", "source": "SD card power regulator"},
        {"name": "PP3V8_MAME2W_TCON", "voltage": "3.8V", "source": "TCON power gated"},
        {"name": "PP3V29_BCKN_MAME2W", "voltage": "3.29V", "source": "Backlight regulator"}
      ]
    }
  }
}
