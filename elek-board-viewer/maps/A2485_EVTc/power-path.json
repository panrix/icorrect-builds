{
  "board": "A2485_EVTc",
  "schematic": "820-02382",
  "description": "Complete power delivery chain from USB-C/MagSafe input to SoC power pins. 7 stages. Pro/Max variant -- 16\" with 42A PP3V8_AON, 5 Monaco instances, 3 Viper stages.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C / MagSafe Input & Initial 5V",
      "description": "3 USB-C ports (2 left, 1 right) + MagSafe. CD3217/CD3218 controllers manage CC signaling and VBUS switching.",
      "nodes": [
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC0", "voltage": "5V->20V", "ic": "UF400 (CD3217B18KE ATC0)", "port": "Left rear", "page": [74, 77]},
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC1", "voltage": "5V->20V", "ic": "UF500 (CD3218I2AKZ2 ATC1)", "port": "Left front", "page": [76, 77]},
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC2", "voltage": "5V->20V", "ic": "UG400 (CD3217B18KE ATC2)", "port": "Right", "page": [83, 84]},
        {"input": "MagSafe cable", "output": "PPVBUS_USBC5", "voltage": "5V->20V", "ic": "U5500 (CD3218I2AKZ2 UPC5)", "port": "J5401 MagSafe (APN 516500767)", "page": [54, 55]}
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217/CD3218 reads firmware ROM, negotiates USB PD to 20V. Happens AFTER SoC hard start at 5V.",
      "sequence": [
        "1. CD3217/CD3218 internal MOSFET passes 5V",
        "2. SoC powers up at 5V (hard start via PMU cascade)",
        "3. M1 Pro/Max SoC sends command to CD3217/CD3218",
        "4. Controller reads ROM via CC lines (ACE5 for MagSafe is SPI ROM ONLY)",
        "5. PD negotiation -> charger transitions to 20V",
        "6. PPVBUS transitions 5V -> 20V",
        "7. Protection isolation passes -> PPBUS_AON at battery voltage"
      ],
      "page": [52, 53, 74, 76, 83]
    },
    {
      "stage": 3,
      "name": "Charger -> PPBUS_AON",
      "description": "Charger IC (U5200 area) converts input to PPBUS_AON. Multi-FET input stage with CHGR_GATE G1-G6 and dual LS230/LS231 inductors.",
      "nodes": [
        {
          "input": "PPDCIN_AON",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter)",
          "ic": "U5200 area (Charger IC, OMIT_TABLE/DFITF0)",
          "enable": "CHGR_AUX_OK (level translation on page 53)",
          "fault": "No PPBUS -> charger IC / CD3217 / U5200 fault",
          "page": [51, 52, 53]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON -> PP3V8_AON (42A design)",
      "description": "U5700 multi-phase buck converts PPBUS_AON to 3.8V always-on rail. 42A ICC MAX (vs 30A on A2442). Controller is RAGCFKID_KOPU. Feeds SPMU, MPMU, and branches to WiFi/BT, display, audio codec, speaker amps, SE.",
      "nodes": [
        {
          "input": "PPBUS_AON (via PP5VZN_P3V8AON)",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 42A ICC MAX)",
          "enable": "P3V8AON_PWR_EN (test point TP5700)",
          "fault": "P3V8AON_FAULT_L",
          "phases": "3 power phases with low-side ISENSE summing amp (page 60)",
          "branches": {
            "to_mpmu": "PP3V8_AON -> ISENSE -> U8100 (MPMU)",
            "to_spmu": "PP3V8_AON -> ISENSE -> U7700 (SPMU)",
            "to_wlbt": "PP3V8_AON -> ISENSE -> WiFi/BT Typhoon module",
            "to_codec": "PP3V8_AON_CODEC -> Audio codec VP",
            "to_se": "PP3V8_AON_SE -> Secure Element U5000",
            "to_spkramp": "PP3V8_AON_C_SPKRAMP -> Speaker amps A-F",
            "to_display": "PP3V8_AON_LCD_SW_VIN -> Display power sequencer",
            "to_hdmi": "PP3V8_AON_HDMI_LDO -> UH901 3.3V LDO"
          },
          "page": [57, 58, 60]
        }
      ]
    },
    {
      "stage": 5,
      "name": "PMU + VR Distribution",
      "description": "PP3V8_AON feeds SPMU (U7700) and MPMU (U8100). MPMU feeds Viper VR (U9300) and Monaco VR (5 instances) for high-current SoC domains. More complex than A2442 (3 Monaco instances).",
      "topology": {
        "pp3v8_aon_feeds": ["U7700 (SPMU)", "U8100 (MPMU)"],
        "mpmu_feeds": ["Viper VR (U9300) -> PCPU domains (3 power stages)", "Monaco VR (UA100-UA500, 5 instances) -> GPU/fabric domains", "Direct buck outputs -> ECPU, SRAM, S1/S2 domains", "LDOs -> AON/fixed domains"],
        "spmu_feeds": ["Direct buck outputs -> SOC, DCS, DISP, FABRIC domains", "LDOs -> AON domains"]
      },
      "viper_vr": {
        "controller": "U9300 (MAX2553/26A)",
        "input": "PP3V8_AON via Viper support caps (5 phase banks PH1-PH5, page 92)",
        "outputs": [
          {"rail": "PPVDD_PCPU0_AWAKESW", "voltage": "Variable DVFS", "load": "PCPU cluster 0", "stage": "Power Stages 1 (page 94)"},
          {"rail": "PPVDD_PCPU1_AWAKESW", "voltage": "Variable DVFS", "load": "PCPU cluster 1 (Max only)", "bom": "Max", "stage": "Power Stages 2 (page 95)"},
          {"rail": "PPVDD_PCPU_SRAM0_AWAKESW", "voltage": "Variable", "load": "PCPU SRAM 0"},
          {"rail": "PPVDD_PCPU_SRAM1_AWAKESW", "voltage": "Variable", "load": "PCPU SRAM 1 (Max only)", "bom": "Max"}
        ],
        "fault": "PVDDVDN_FAULT_L",
        "page": [92, 93, 94, 95, 96]
      },
      "monaco_vr": {
        "instances": [
          {"name": "Monaco 0 (UA100)", "cfg": "C0, A0:A0, B0:D0", "page": 101},
          {"name": "Monaco 1 (UA200)", "cfg": "C1, A1, OTP=BP_", "page": 102},
          {"name": "Monaco 2 (UA300)", "cfg": "C2, A1, OTP=BP_", "page": 103},
          {"name": "Monaco 3 (UA400)", "cfg": "C3, B0, OTP=IP_", "page": 104},
          {"name": "Monaco 4 (UA500)", "cfg": "sC/1C/2C multi-config", "page": 105}
        ],
        "input": "PP3V8_AON via MPMU buck output (Monaco input caps 11uF APN 138500328)",
        "outputs": "PPVDD_S0VE, PPVDD_S0VS, PPVDD_MCPW, PPVDD_S0CL_CAMU, PPVDD_GACS, PPVDD_S0DL, PPVDD_AGXS, PPVDD_S0KE, PPVDD_S0PE, PPVDD_AFR, PP3V3_S0MWLF_S1",
        "fault": "MONACO_ALERT_L (via CLVR GPIO connections on each instance)",
        "page": [101, 102, 103, 104, 105, 120, 140]
      },
      "page": [77, 78, 79, 80, 81, 82, 83, 84, 85, 92, 93, 94, 95, 96, 101, 102, 103, 104, 105]
    },
    {
      "stage": 6,
      "name": "Standalone Regulators & Load Switches",
      "description": "TPS62130 produces PP5V_S2. LT8640 (UF800) produces PP5V_USBC01. TPS62180 (UG800) produces PP5V_USBC23. TPS62135 (UK830) produces PP3V3_AWAKE_SW_SD.",
      "regulators": [
        {"input": "PPBUS_AON", "output": "PP5V_S2", "voltage": "5.14V", "ic": "TPS62130 (page 122)", "enable": "P5V2TPS_PWR_EN", "specs": "2.1A max, 1.25MHz, startup 4.7-10.5ms"},
        {"input": "PPVIN_5VUSBC01", "output": "PP5V_USBC01", "voltage": "5.23V", "ic": "UF800 (LT8640S-2#PBF)", "enable": "PSVUSBC01_EN", "specs": "6.6A EDC, 1.5MHz"},
        {"input": "PPVIN_5VUSBC23", "output": "PP5V_USBC23", "voltage": "5.23V", "ic": "UG800 (TPS62180)", "enable": "PSVUSBC23_EN_R", "specs": "3.3A Icc, 1.9-2.0MHz"},
        {"input": "PP3V3SD_AVIN", "output": "PP3V3_AWAKE_SW_SD", "voltage": "3.3V", "ic": "UK830 (TPS62135)", "enable": "SD_PWR_EN", "specs": "2.08A, 1.25MHz"}
