          "page": [
            31,
            32,
            33
          ]
        }
      ],
      "components": [
        "UF400",
        "UF500",
        "UF600",
        "J5401"
      ],
      "input_rails": [
        "PPVBUS_USBC0",
        "PPVBUS_USBC1",
        "PPVBUS_USBC23"
      ],
      "output_rails": [
