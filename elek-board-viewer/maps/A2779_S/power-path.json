        "PPVBUS_USBC1",
        "PPVBUS_USBC23"
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 reads firmware from SPI ROM, negotiates USB PD to request 20V from charger adapter.",
      "sequence": [
        "1. CD3217 internal MOSFET passes 5V",
        "2. SoC powers up at 5V (hard start)",
        "3. M2 Pro SoC sends command to CD3217",
        "4. CD3217 reads ROM info via SPI ROM",
        "5. CD3217 sends PD Source_Capabilities request via CC line",
        "6. Charger adapter responds with 20V capability",
        "7. PPVBUS_USBCx transitions from 5V \u2192 20V",
        "8. Protection isolation passes \u2192 PPBUS_AON established"
      ],
      "signals": {
        "cc_lines": [
          "USBC0_CC1",
          "USBC0_CC2",
          "USBC1_CC1",
          "USBC1_CC2",
          "USBC2_CC1",
          "USBC2_CC2"
        ],
        "spi_rom": [
          "SPI_UPC0 (ATC0 firmware)",
          "SPI_UPC1 (ATC1 firmware)",
          "SPI_UPC2 (ATC2 firmware)"
        ],
        "charger_aux": "CHGR_AUX_OK (indicates charger ready, page 30)"
      },
      "page": [
        29,
        30,
        74,
        75,
        83
      ],
      "components": [
        "UF400",
        "UF500",
        "UF600"
      ],
      "input_rails": [
