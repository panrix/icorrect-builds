        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 30A ICC MAX, 3 phases)",
          "enable": "PPVAON_PWR_EN (from J5150 battery connector)",
          "fault": "PPVAON_FAULT_L (active low)",
          "current_sense": "U5910/U6040 (PP3V8_AON current sense via PPVAON_ISNS_P/N, summing amp page 36)",
          "branches": [
            "PP3V8_AON_VDDMAIN",
            "PP3V8_AON_WLBT (WiFi/BT)",
            "PP3V8_AON_DPG_F (peripherals)"
          ],
          "delay": "3V8 VR enable delayed by circuit on page 30 (DELAY FOR 3.8V VR ENABLE)",
          "page": [
            34,
            35,
