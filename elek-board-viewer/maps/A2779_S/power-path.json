      "name": "Charger \u2192 PPBUS_AON",
      "description": "Charger IC converts USB-C/MagSafe input to PPBUS_AON. Battery also connects to PPBUS_AON. This is the main system power bus.",
      "nodes": [
        {
          "input": "PPCON_ACNSW",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter)",
          "ic": "Charger IC (page 29)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT (J5150/U5150 gasket)",
          "fault": "No PPBUS \u2192 charger IC fault, CD3217 not negotiating, or battery disconnected",
          "page": [
