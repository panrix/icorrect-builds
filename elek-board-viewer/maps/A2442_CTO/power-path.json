{
  "board": "A2442_CTO",
  "schematic": "820-02443",
  "WARNING": "CTO variant (820-02443, X2719 MLB-C). SVR AON is 42A design. Viper has 3 stage pages. Monaco has 5 instances. Page numbers differ from base A2442 (820-02098).",
  "description": "Complete power delivery chain from USB-C/MagSafe input to SoC power pins. 7 stages. CTO Pro/Max variant — more complex than base due to 42A SVR AON, 3 Viper stage pages, and 5 Monaco instances.",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C / MagSafe Input & Initial 5V",
      "description": "3 USB-C ports (2 left, 1 right) + MagSafe. CD3217 controllers manage CC signaling and VBUS switching.",
      "nodes": [
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC0", "voltage": "5V->20V", "ic": "UF400 (CD3217 ATC0)", "port": "Left rear", "page": [76, 78]},
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC1", "voltage": "5V->20V", "ic": "UF500 (CD3217 ATC1)", "port": "Left front", "page": [77, 78]},
        {"input": "USB-C cable (5V)", "output": "PPVBUS_USBC2", "voltage": "5V->20V", "ic": "UG400 (CD3217 ATC2)", "port": "Right", "page": [85, 86]},
        {"input": "MagSafe cable", "output": "PPVBUS_USBC5", "voltage": "5V->20V", "ic": "MagSafe Port Controller (UPC5)", "port": "J5401 MagSafe", "page": [31, 32]}
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 reads firmware ROM, negotiates USB PD to 20V. Happens AFTER SoC hard start at 5V.",
      "sequence": [
        "1. CD3217 internal MOSFET passes 5V",
        "2. SoC powers up at 5V (hard start via PMU cascade)",
        "3. M1 Pro/Max SoC sends command to CD3217",
        "4. CD3217 reads ROM via CC lines",
        "5. PD negotiation -> charger transitions to 20V",
        "6. PPVBUS transitions 5V -> 20V",
        "7. Protection isolation passes -> PPBUS_AON at battery voltage"
      ],
      "signals": {
        "cc_lines": ["USBC0_CC1/CC2", "USBC1_CC1/CC2", "USBC2_CC1/CC2"],
        "spi_roms": ["SPI_UPC0", "SPI_UPC1", "SPI_UPC2", "SPI_UPC5"],
        "charger_ready": "CHGR_AUX_OK"
      },
      "page": [29, 30, 76, 77, 85]
    },
    {
      "stage": 3,
      "name": "Charger -> PPBUS_AON",
      "description": "Charger IC (U5200 area) converts input to PPBUS_AON. Multi-FET input stage.",
      "nodes": [
        {
          "input": "PPDCIN_AON",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter)",
          "ic": "U5200 area (Charger IC)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT",
          "fault": "No PPBUS -> charger IC / CD3217 / U5200 fault",
          "test_point": "CR765 area — PPBUS_AON decoupling",
          "page": [28, 29, 30]
        }
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON -> PP3V8_AON (42A CTO Design)",
      "description": "U5700 multi-phase buck converts PPBUS_AON to 3.8V always-on rail. CTO: 42A design (base: 30A). BOM thresholds: BOM0=30A, BOM1=35A, BOM2=42A. 3-phase with summing amp ISENSE/ILIMIT. Feeds SPMU, MPMU, and branches to WiFi/BT, display, peripherals.",
      "cto_difference": "42A design vs 30A base — higher current to support Max GPU power delivery via extended Monaco VR instances",
      "nodes": [
        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5700 (SVR AON, 42A ICC MAX CTO)",
          "enable": "PPVAON_PWR_EN",
          "fault": "PPVAON_FAULT_L (active low)",
          "phases": ["PP3V8AON_PH1", "PP3V8AON_PH2", "PP3V8AON_PH3", "PP3V8AON_SW2_PH2", "PP3V8AON_SW3_PH3"],
          "branches": {
            "to_mpmu": "PP3V8_AON_MPMU_ISNS -> U8100",
