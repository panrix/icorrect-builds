        {
          "input": "PPBUS_AON",
          "output": "PP3V3_S2",
          "voltage": "3.3V",
          "ic": "3V3 S2 VR",
          "enable": "P3V3S2_PWR_EN",
          "page": 135
        }
      ],
      "load_switches": [
        {"input": "PP5V_S2", "output": "PP5V_S2SW_USBC01", "load": "Left USB-C ports", "page": 76},
        {"input": "PP5V_S2", "output": "PP5V_S2SW_USBC23", "load": "Right USB-C + HDMI", "page": 83},
        {"input": "PP3V3_S2", "output": "PP3V3_S2SW_USBC0", "load": "ATC0", "page": 76},
        {"input": "PP3V3_S2", "output": "PP3V3_S2SW_USBC1", "load": "ATC1", "page": 76},
        {"input": "PP3V3_S2", "output": "PP3V3_S2SW_USBC2", "load": "ATC2", "page": 83},
        {"input": "PP3V3_S2", "output": "PP3V3_S2_IPD", "load": "IPD subsystem", "page": 136},
        {"input": "PPBUS_AON", "output": "PPBUS_NAND0", "load": "SSD0 via Ocarina", "page": 101},
        {"input": "PPBUS_AON", "output": "PPBUS_NAND1", "load": "SSD1 via Ocarina", "page": 106}
      ]
