        {"name": "PPVDS5_S2SM_CIO", "voltage": "0.855V", "source": "MPMU LDO 10"},
        {"name": "PP3V3_S2_LDO", "voltage": "3.3V", "source": "MPMU LDO 7"},
        {"name": "PP3V3_S2M_SNS", "voltage": "3.3V", "source": "MPMU LDO 13"},
        {"name": "PP3V3_S2SM_CIO", "voltage": "3.3V", "source": "MPMU LDO 14"},
        {"name": "PP1V2_S2_C10", "voltage": "1.2V", "source": "MPMU LDO 20"},
        {"name": "PP1V2_USBC_VDDIO", "voltage": "1.2V", "source": "UF900"},
        {"name": "PP3V3_S2_WLBT_1MS", "voltage": "3.3V", "source": "Load switch from PP3V3_S2"},
        {"name": "PP1V25_S2_WLBT_1MS", "voltage": "1.25V", "source": "Load switch from PP1V25_S2"},
        {"name": "PP3V3_AONSW_IPD", "voltage": "3.3V", "source": "IPD load switch from PP3V3_S2"},
        {"name": "PP5V_S2_ALSCAM", "voltage": "5V", "source": "Load switch from PP5V_S2"},
        {"name": "PP1V8_DFR", "voltage": "1.8V", "source": "UT700 DFR LDO"},
        {"name": "PP3V3_DFR", "voltage": "3.3V", "source": "UT710 DFR LDO"},
        {"name": "PP1V8_AONSW_KBDLO", "voltage": "1.8V", "source": "KBD 1V8 S2 LDO"}
      ]
    },
    "S1": {
      "description": "Light sleep. Core SoC domains retained at low voltage.",
      "wake_condition": "S2 domain active + SoC sleep state controller asserts S1 enables",
      "rails": [
        {"name": "PP0V75_S1_SRAM", "voltage": "0.75V", "source": "SPMU BUCK 5"},
