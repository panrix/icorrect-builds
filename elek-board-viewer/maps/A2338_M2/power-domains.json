        {"name": "PP3V8_MAME_NAND_VDDL", "voltage": "3.8V", "source": "SPMU BUCK 12 SW6/7"},
        {"name": "PP1V8_MAME_SPMU_GFS5", "voltage": "1.8V", "source": "SPMU BUCK 3 SW4"},
        {"name": "PPVOUT_LCDBKLT", "voltage": "Variable", "source": "LCD backlight boost"},
        {"name": "PPVOUT_KBDLED", "voltage": "Variable", "source": "Keyboard backlight driver"},
        {"name": "PPVD5_MAME_DFR", "voltage": "Variable", "source": "DFR power rail"}
