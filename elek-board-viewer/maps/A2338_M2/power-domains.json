        {"name": "PP1V21_S2", "voltage": "1.21V", "source": "MPMU BUCK 3"},
        {"name": "PP1V8_S2M", "voltage": "1.8V", "source": "UC820 load switch"},
        {"name": "PP1V12_S2M_AMPH", "voltage": "1.12V", "source": "SPMU BUCK 14"},
        {"name": "PPVDD_S2M_VDDQ5", "voltage": "1.85V", "source": "MPMU BUCK 4"},
