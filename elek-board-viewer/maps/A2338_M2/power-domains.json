{
  "board": "A2338",
  "schematic": "820-02773",
  "description": "All rails grouped by power state (sleep domain). G3H = always present with AC, AON = always on with battery, S5-S0 = progressively more awake.",
  "domains": {
    "G3H": {
      "description": "Present whenever AC power is connected (pre-charger, pre-battery)",
      "wake_condition": "USB-C cable inserted",
      "rails": [
        {"name": "PPVBUS_USBC0", "voltage": "5V/20V", "source": "UF400 (CD3217)"},
        {"name": "PPVBUS_USBC1", "voltage": "5V/20V", "source": "UF500 (CD3217)"},
        {"name": "PPCON_ACNSW", "voltage": "~5-20V", "source": "Charger input path"},
        {"name": "PPSC26_ADR_CHSR", "voltage": "~5-20V", "source": "Fused VBUS path"}
      ]
    },
    "AON": {
      "description": "Always on when battery or charger connected. Stays up in all sleep states.",
      "wake_condition": "PPBUS_AON present (battery connected or charger active)",
      "enable_signals": ["PPVAON_PWR_EN (for SVR AON)", "BMU SYS_DETECT (J5150 gasket)"],
      "rails": [
        {"name": "PPBUS_AON", "voltage": "12.6V", "source": "Charger IC U5200 / Battery"},
        {"name": "PPVBAT_AON", "voltage": "~12.6V", "source": "Battery via J5150A solder pads"},
        {"name": "PP3V8_AON", "voltage": "3.8V", "source": "SVR AON (36A/30A)"},
        {"name": "PP3V8_AON_VDDMAIN", "voltage": "3.8V", "source": "PP3V8_AON branch"},
        {"name": "PP3V8_AON_WLBT", "voltage": "3.8V", "source": "PP3V8_AON branch"},
        {"name": "PP3V8_AON_DPG_F", "voltage": "3.8V", "source": "PP3V8_AON filtered"},
        {"name": "PP1V8_AON_MPMU", "voltage": "1.8V", "source": "MPMU LDO 9"},
        {"name": "PP1V8_AON_SPMU", "voltage": "1.8V", "source": "SPMU LDO 9"},
        {"name": "PP1V2_AON_MPMU", "voltage": "1.2V", "source": "MPMU LDO 9B"},
        {"name": "PP1V2_AON_SPMU", "voltage": "1.2V", "source": "SPMU LDO 9B"},
        {"name": "PP3V_AON", "voltage": "3.0V", "source": "MPMU LDO 2"},
        {"name": "PP1V05_LDOINT_MPMU", "voltage": "1.05V", "source": "MPMU LDOINT"},
