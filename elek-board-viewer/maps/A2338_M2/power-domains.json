        {"name": "PPBUS_AONSW_LCD", "voltage": "12.6V", "source": "Load switch from PPBUS_AON"}
      ]
    },
    "S2": {
      "description": "System sleep / standby. Memory retention active. Most peripherals off.",
      "wake_condition": "PMU enable signals from AON domain. P5VS2_PWR_EN, P3V3S2_PWR_EN asserted.",
      "enable_signals": ["P5VS2_PWR_EN (SPMU GPIO)", "P3V3S2_PWR_EN (SPMU GPIO)"],
      "rails": [
        {"name": "PP5V_S2", "voltage": "5.14V", "source": "UC300 (TPS62130)"},
        {"name": "PP3V3_S2", "voltage": "3.3V", "source": "UC710"},
        {"name": "PP5V_S2_UPC", "voltage": "5.23V", "source": "UF800"},
