{
  "board": "A2338_M2",
  "schematic": "820-02773",
  "description": "Complete power delivery chain from USB-C input to SoC power pins. 7 sequential stages. MacBook Pro 13\" M2 (X2487 MLB).",
  "stages": [
    {
      "stage": 1,
      "name": "USB-C Input & Initial 5V",
      "description": "USB-C connector supplies 5V default. CD3217 port controllers manage CC signaling and VBUS switching. Two USB-C ports: left rear (debug) and left front.",
      "nodes": [
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC0",
          "voltage": "5V (initial)",
          "ic": "UF400 (CD3217 ATC0)",
          "port": "Left Rear USB-C (Debug Port)",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication \u2192 cable/connector fault",
          "test_point": "CF400/CF401 (PPVBUS_USBC0 decoupling)",
          "page": [
            61,
            66
          ]
        },
        {
          "input": "USB-C cable (5V default)",
          "output": "PPVBUS_USBC1",
          "voltage": "5V (initial)",
          "ic": "UF500 (CD3217 ATC1)",
          "port": "Left Front USB-C",
          "enable": "Cable insertion detected via CC1/CC2",
          "fault": "No CC communication \u2192 cable/connector fault",
          "test_point": "CF500/CF503 (PPVBUS_USBC1 decoupling)",
          "page": [
            61,
            67
          ]
        }
      ],
      "components": [
        "UF400",
        "UF500"
      ]
    },
    {
      "stage": 2,
      "name": "PD Negotiation & 20V Boost",
      "description": "CD3217 reads firmware from SPI ROM via CC lines, negotiates USB PD to request 20V from charger adapter. Based on M1/M2 power-on reference: this happens AFTER initial SoC hard start at 5V.",
      "sequence": [
        "1. CD3217 internal MOSFET passes 5V",
        "2. SoC powers up at 5V (hard start)",
        "3. M2 SoC sends command to CD3217",
        "4. CD3217 reads ROM info via USBC0_CC1/USBC0_CC2",
        "5. CD3217 sends PD Source_Capabilities request via CC line",
        "6. Charger adapter responds with 20V capability",
        "7. PPVBUS_USBC0 transitions from 5V \u2192 20V",
        "8. Protection isolation passes \u2192 PPBUS_AON established at battery voltage (~12.6V)"
      ],
      "signals": {
        "cc_lines": [
          "USBC0_CC1",
          "USBC0_CC2",
          "USBC1_CC1",
          "USBC1_CC2"
        ],
        "spi_rom": [
          "SPI_UPC0 (ATC0 firmware)",
          "SPI_UPC1 (ATC1 firmware)"
        ],
        "charger_aux": "CHGR_AUX_OK (indicates charger ready)",
        "charger_int": "CHGR_INT_L (charger interrupt, active low)"
      },
      "page": [
        25,
        26,
        64,
        66,
        67
      ],
      "components": [
        "UF400",
        "UF500"
      ]
    },
    {
      "stage": 3,
      "name": "Charger \u2192 PPBUS_AON",
      "description": "Charger IC U5200 converts USB-C input to PPBUS_AON. Battery also connects via J5150A solder pads to PPVBAT_AON/PPBUS_AON. This is the main system power bus.",
      "nodes": [
        {
          "input": "PPCON_ACNSW / USB-C VBUS",
          "output": "PPBUS_AON",
          "voltage": "12.6V (battery) / ~20V (adapter, before regulation)",
          "ic": "U5200 (Charger IC, XMC260 inductor)",
          "enable": "CHGR_AUX_OK, BMU SYS_DETECT (J5150 gasket via TP5100/TP5101)",
          "fault": "No PPBUS \u2192 charger IC fault, CD3217 not negotiating, or battery disconnected",
          "test_point": "C5900 area / PPBUS_AON caps \u2192 expect 12V",
          "page": [
            24,
            25,
            27
          ]
        }
      ],
      "components": [
        "U5200"
      ]
    },
    {
      "stage": 4,
      "name": "SVR AON \u2192 PP3V8_AON",
      "description": "30A ICC MAX controller (page 28) with 30A ICC MAX output stage (page 29) converts PPBUS_AON down to 3.8V always-on rail. This is the single most important rail \u2014 it powers both PMUs.",
      "nodes": [
        {
          "input": "PPBUS_AON",
          "output": "PP3V8_AON",
          "voltage": "3.8V",
          "ic": "U5709 (RAA235645C SVR AON, 30A ICC MAX, multi-phase buck)",
          "enable": "PPVAON_PWR_EN (via U5349 delay circuit from CHGR_EN_RVR, page 26)",
          "fault": "PPVAON_FAULT_L (active low)",
          "current_sense": "U5910 (PP3V8_AON current sense via PPVAON_ISNS_P/N, page 30)",
          "test_point": "PP3V8_AON capacitors area \u2192 expect 3.8V",
          "page": [
            26,
            28,
            29,
            30
          ]
        },
        {
          "input": "PP3V8_AON",
          "output": "PP3V8_AON_VDDMAIN",
