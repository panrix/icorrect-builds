# Chief of Staff bridge env — copy to chief-of-staff.env and fill values.
# Bridge refuses to start if any required field is empty.

TELEGRAM_BOT_TOKEN=
ALLOWED_USER_ID=
KILL_HMAC=
AGENT_NAME=chief-of-staff
TMUX_SESSION=chief-of-staff

# Optional — needed for Monday kill-switch path (Path 2) + Monday sync
MONDAY_TOKEN=
MONDAY_KILL_SWITCH_ITEM_ID=

# Optional — needed for nightly restic backup (Stage B setup)
HETZNER_STORAGEBOX_USER=
HETZNER_STORAGEBOX_HOST=
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
