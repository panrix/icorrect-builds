# Chief of Staff bridge env — copy to chief-of-staff.env and fill values.
# The bridge refuses to start if any REQUIRED field is empty.
# OPTIONAL fields disable specific features when absent (bridge still boots).

# ----- REQUIRED -----
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_ID=
AGENT_NAME=chief-of-staff
TMUX_SESSION=chief-of-staff
# TZ is enforced to Asia/Singapore by the systemd unit; set it there, not here.

# ----- OPTIONAL: kill-switch Path 1 (signed /kill <passphrase>) -----
# When absent, Path 1 is disabled. Paths 2 (Monday column) + 3 (SSH + BRIDGE_LOCKED=1) still work.
# Format accepted (bot.js auto-detects):
#   1) Plain passphrase secret (bot derives expected HMAC on startup)
#   2) 64-char hex digest: hmac-sha256(AGENT_NAME, passphrase) precomputed
#   3) "hmac-sha256:<secret>:<expected_hex>" explicit form
KILL_HMAC=

# ----- OPTIONAL: kill-switch Path 2 (Monday column poll) + Monday sync -----
# When absent, Path 2 is disabled.
MONDAY_TOKEN=
MONDAY_KILL_SWITCH_ITEM_ID=

# ----- OPTIONAL: nightly restic backup to Hetzner Storage Box (Stage B) -----
# When absent, claude-backup@.timer can still be enabled but will log a
# backup-fail incident on each run until populated.
HETZNER_STORAGEBOX_USER=
HETZNER_STORAGEBOX_HOST=
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
