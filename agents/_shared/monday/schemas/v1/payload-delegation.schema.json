{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panrix.local/agents/monday/schemas/v1/payload-delegation.schema.json",
  "title": "Monday Queue Payload - Delegation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "from",
    "to",
    "task_summary",
    "outcome",
    "linked_record"
  ],
  "properties": {
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "in-progress",
        "cancelled",
        "superseded"
      ]
    },
    "linked_record": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
