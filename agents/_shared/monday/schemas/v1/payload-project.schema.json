{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panrix.local/agents/monday/schemas/v1/payload-project.schema.json",
  "title": "Monday Queue Payload - Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "status",
    "health",
    "owner",
    "next_action",
    "last_activity_ts"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "done"
      ]
    },
    "health": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "last_activity_ts": {
      "type": "string",
      "format": "date-time"
    }
  }
}
