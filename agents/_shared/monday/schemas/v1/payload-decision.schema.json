{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panrix.local/agents/monday/schemas/v1/payload-decision.schema.json",
  "title": "Monday Queue Payload - Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "decision",
    "rationale",
    "linked_record"
  ],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "linked_record": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
