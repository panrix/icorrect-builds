{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panrix.local/agents/monday/schemas/v1/payload-agent.schema.json",
  "title": "Monday Queue Payload - Agent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "status",
    "model",
    "bot_username",
    "last_activity_ts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "alive",
        "paused",
        "retired"
      ]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "bot_username": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_activity_ts": {
      "type": "string",
      "format": "date-time"
    }
  }
}
