#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -lt 3 ] || [ "$#" -gt 4 ]; then
  printf 'usage: delegate <session> <window> <message> [--timeout=300]\n' >&2
  exit 64
fi

session="$1"
window="$2"
message="$3"
timeout_s=300

if [ "$#" -eq 4 ]; then
  case "$4" in
    --timeout=*)
      timeout_s="${4#--timeout=}"
      ;;
    *)
      printf 'delegate: unsupported option %s\n' "$4" >&2
      exit 64
      ;;
  esac
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
shared_dir="$(cd "$script_dir/.." && pwd)"
logs_dir="$shared_dir/logs"
work_dir="$(mktemp -d "$logs_dir/delegate.XXXXXX")"
capture_file="$work_dir/capture.txt"

cleanup() {
  rm -rf "$work_dir"
}
trap cleanup EXIT

mkdir -p "$logs_dir"

target="${session}:${window}"
tmux has-session -t "$session" >/dev/null 2>&1
tmux send-keys -t "$target" "$message" C-m

started_epoch="$(date +%s)"
last_hash=""
idle_since=0

while true; do
  tmux capture-pane -p -t "$target" -S - >"$capture_file"
  current_hash="$(sha256sum "$capture_file" | awk '{print $1}')"
  now_epoch="$(date +%s)"

  if [ "$current_hash" = "$last_hash" ]; then
    if [ "$idle_since" -eq 0 ]; then
      idle_since="$now_epoch"
    fi
    if [ $((now_epoch - idle_since)) -ge 5 ]; then
      break
    fi
  else
    idle_since=0
    last_hash="$current_hash"
  fi

  if [ $((now_epoch - started_epoch)) -ge "$timeout_s" ]; then
    break
  fi

  sleep 1
done

duration_s="$(( $(date +%s) - started_epoch ))"
captured_output="$(cat "$capture_file")"

python3 - "$logs_dir/delegations.jsonl" "$session" "$window" "$message" "$captured_output" "$duration_s" <<'PY'
import datetime as dt
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
line = {
    "ts": dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "session": sys.argv[2],
    "window": sys.argv[3],
    "message": sys.argv[4],
    "captured_output": sys.argv[5],
    "duration_s": int(sys.argv[6]),
}
with path.open("a", encoding="utf-8") as handle:
    handle.write(json.dumps(line, ensure_ascii=False) + "\n")
PY

cat "$capture_file"
