#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
shared_dir="$(cd "$script_dir/.." && pwd)"
state_dir="$shared_dir/state"
logs_dir="$shared_dir/logs"
scratch_dir="$state_dir/handoff-scratch"
quarantine_dir="$scratch_dir/quarantine"
imports_dir="$state_dir/imports"
queue_file="$state_dir/monday-queue.jsonl"
offset_file="$state_dir/queue-validated-offset.txt"
skill_log="$state_dir/skill-invocations.jsonl"
bridge_incidents="$logs_dir/bridge-incidents.jsonl"
today_sg="$(TZ=Asia/Singapore date +%F)"
flag_file="$state_dir/anomaly-reported-${today_sg}.flag"
work_dir="$(mktemp -d "$state_dir/sweep-runtime.XXXXXX")"
anomalies_file="$work_dir/anomalies.txt"

cleanup() {
  rm -rf "$work_dir"
}
trap cleanup EXIT

mkdir -p "$state_dir" "$logs_dir" "$scratch_dir" "$quarantine_dir" "$imports_dir"
: >"$anomalies_file"

append_anomaly() {
  printf '%s\n' "$1" >>"$anomalies_file"
}

log_incident() {
  local kind="$1"
  local message="$2"
  python3 - "$bridge_incidents" "$kind" "$message" <<'PY'
import datetime as dt
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
path.parent.mkdir(parents=True, exist_ok=True)
line = {
    "ts": dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "kind": sys.argv[2],
    "message": sys.argv[3],
}
with path.open("a", encoding="utf-8") as handle:
    handle.write(json.dumps(line, ensure_ascii=False) + "\n")
PY
}

find "$scratch_dir" -maxdepth 1 -type f \( -name '*.bak-*' -o -name '*.tmp-*' \) -mmin +1440 -print0 | while IFS= read -r -d '' stale_file; do
  mv "$stale_file" "$quarantine_dir/"
  append_anomaly "stale handoff quarantined: $(basename "$stale_file")"
done

if command -v logrotate >/dev/null 2>&1 && [ -f "$shared_dir/logrotate/claude-agents.conf" ]; then
  logrotate -s "$state_dir/logrotate.state" "$shared_dir/logrotate/claude-agents.conf" || append_anomaly "logrotate failed"
fi

find "$imports_dir" -type f -name '*.consumed' -mtime +7 -delete

node - "$queue_file" "$offset_file" "$shared_dir/monday/queue-validator.js" >"$work_dir/queue-result.json" <<'NODE'
const fs = require("node:fs");
const [queuePath, offsetPath, validatorPath] = process.argv.slice(2);
const { validate } = require(validatorPath);

const result = {
  ok: true,
  reason: null,
  newOffset: 0,
  lineNumber: null
};

if (!fs.existsSync(queuePath)) {
  const currentOffset = fs.existsSync(offsetPath) ? Number(fs.readFileSync(offsetPath, "utf8").trim() || "0") : 0;
  result.newOffset = Number.isFinite(currentOffset) ? currentOffset : 0;
  console.log(JSON.stringify(result));
  process.exit(0);
}

const currentOffset = fs.existsSync(offsetPath) ? Number(fs.readFileSync(offsetPath, "utf8").trim() || "0") : 0;
const buffer = fs.readFileSync(queuePath);
let offset = Math.min(Math.max(currentOffset, 0), buffer.length);
let lineNumber = 0;
for (let i = 0; i < offset; i += 1) {
  if (buffer[i] === 10) {
    lineNumber += 1;
  }
}

while (offset < buffer.length) {
  const nextNewline = buffer.indexOf(10, offset);
  const end = nextNewline === -1 ? buffer.length : nextNewline;
  const rawLine = buffer.subarray(offset, end).toString("utf8").trim();
  lineNumber += 1;

  if (!rawLine) {
    offset = nextNewline === -1 ? buffer.length : end + 1;
    continue;
  }

  let parsed;
  try {
    parsed = JSON.parse(rawLine);
  } catch (error) {
    result.ok = false;
    result.reason = `line ${lineNumber}: invalid JSON (${error.message})`;
    result.lineNumber = lineNumber;
    result.newOffset = offset;
    console.log(JSON.stringify(result));
    process.exit(0);
  }

  const verdict = validate(parsed);
  if (!verdict.ok) {
    result.ok = false;
    result.reason = `line ${lineNumber}: ${JSON.stringify(verdict.errors)}`;
    result.lineNumber = lineNumber;
    result.newOffset = offset;
    console.log(JSON.stringify(result));
    process.exit(0);
  }

  offset = nextNewline === -1 ? buffer.length : end + 1;
}

result.newOffset = offset;
console.log(JSON.stringify(result));
NODE

queue_ok="$(python3 - "$work_dir/queue-result.json" <<'PY'
import json, sys
print("true" if json.loads(open(sys.argv[1], encoding="utf-8").read())["ok"] else "false")
PY
)"

if [ "$queue_ok" = "true" ]; then
  python3 - "$work_dir/queue-result.json" "$offset_file" <<'PY'
import json
import sys
from pathlib import Path

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
Path(sys.argv[2]).write_text(str(payload["newOffset"]), encoding="utf-8")
PY
else
  queue_reason="$(python3 - "$work_dir/queue-result.json" <<'PY'
import json, sys
print(json.loads(open(sys.argv[1], encoding="utf-8").read())["reason"])
PY
)"
  append_anomaly "queue integrity failure: $queue_reason"
  log_incident "queue-integrity" "$queue_reason"
fi

disk_use_pct="$(df -P "$shared_dir" | awk 'NR==2 {gsub(/%/,"",$5); print $5}')"
if [ "${disk_use_pct:-0}" -gt 85 ]; then
  append_anomaly "disk usage warning: ${disk_use_pct}%"
  log_incident "disk-warning" "Disk usage is ${disk_use_pct}% on $(df -P "$shared_dir" | awk 'NR==2 {print $6}')"
fi

if [ -f "$skill_log" ]; then
  python3 - "$skill_log" "$work_dir/skill-invocations.pruned" <<'PY'
import datetime as dt
import json
import sys
from pathlib import Path

source = Path(sys.argv[1])
dest = Path(sys.argv[2])
cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(hours=2)
kept = []

for line in source.read_text(encoding="utf-8").splitlines():
    if not line.strip():
        continue
    item = json.loads(line)
    end_ts = item.get("end_ts")
    start_ts = item.get("start_ts")
    if not end_ts:
        kept.append(item)
        continue
    if start_ts:
        started = dt.datetime.fromisoformat(start_ts.replace("Z", "+00:00"))
        if started >= cutoff:
            kept.append(item)

dest.write_text("".join(json.dumps(item, ensure_ascii=False) + "\n" for item in kept), encoding="utf-8")
PY
  mv "$work_dir/skill-invocations.pruned" "$skill_log"
fi

if [ -s "$anomalies_file" ] && [ ! -e "$flag_file" ]; then
  if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -n "${TELEGRAM_RICKY_ID:-}" ]; then
    message="$(printf 'agents sweep-runtime anomalies (%s)\n%s\n' "$today_sg" "$(cat "$anomalies_file")")"
    curl -fsS --max-time 30 -X POST \
      "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      -d "chat_id=${TELEGRAM_RICKY_ID}" \
      --data-urlencode "text=${message}" >/dev/null || true
  fi
  printf '%s\n' "$today_sg" >"$flag_file"
fi
