#!/usr/bin/env bash

set -euo pipefail

usage() {
  printf 'usage: write-state <target-file> <source-content-file-or-stdin>\n' >&2
}

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage
  exit 64
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
shared_dir="$(cd "$script_dir/.." && pwd)"
scratch_dir="$shared_dir/state/handoff-scratch"
locks_dir="$scratch_dir/locks"
target_file="$1"
source_arg="${2:--}"
lock_timeout="${WRITE_STATE_LOCK_TIMEOUT:-10}"

mkdir -p "$scratch_dir" "$locks_dir"

basename_target="$(basename "$target_file")"
lock_file="$locks_dir/${basename_target}.lock"
handoff_id="$(cat /proc/sys/kernel/random/uuid)"
work_dir="$(mktemp -d "$scratch_dir/work.XXXXXX")"
input_file="$work_dir/input"
prepared_file="$work_dir/prepared"
had_original=0
committed=0

bak_file="$scratch_dir/${basename_target}.bak-${handoff_id}"
tmp_file="$scratch_dir/${basename_target}.tmp-${handoff_id}"

cleanup() {
  rm -rf "$work_dir"
  if [ "$committed" -eq 0 ]; then
    rm -f "$tmp_file"
  fi
}
trap cleanup EXIT

if [ "$source_arg" = "-" ] || [ "$#" -eq 1 ]; then
  cat >"$input_file"
else
  cp "$source_arg" "$input_file"
fi

exec 9>"$lock_file"
if ! flock -w "$lock_timeout" 9; then
  printf 'write-state: timed out acquiring lock for %s after %ss\n' "$target_file" "$lock_timeout" >&2
  exit 73
fi

mkdir -p "$(dirname "$target_file")"

if [ -e "$target_file" ]; then
  cp "$target_file" "$bak_file"
  had_original=1
fi

python3 - "$input_file" "$prepared_file" <<'PY'
import ast
import hashlib
import json
import re
import sys
from pathlib import Path

source_path = Path(sys.argv[1])
target_path = Path(sys.argv[2])
text = source_path.read_text(encoding="utf-8")

if not text.startswith("---\n"):
    target_path.write_text(text, encoding="utf-8")
    raise SystemExit(0)

match = re.match(r"^---\n(.*?)\n---\n?", text, re.S)
if not match:
    target_path.write_text(text, encoding="utf-8")
    raise SystemExit(0)

frontmatter = match.group(1)
body = text[match.end():]
entries = []

def parse_value(raw: str):
    value = raw.strip()
    if value in {"", "null", "Null", "NULL", "~"}:
        return None
    lowered = value.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    if re.fullmatch(r"-?\d+", value):
        return int(value)
    if re.fullmatch(r"-?\d+\.\d+", value):
        return float(value)
    if (value.startswith('"') and value.endswith('"')) or (value.startswith("'") and value.endswith("'")):
        return ast.literal_eval(value)
    return value

for line in frontmatter.splitlines():
    if not line.strip():
        continue
    if line.lstrip().startswith("#"):
        continue
    if ":" not in line:
        raise SystemExit(f"Unsupported frontmatter line: {line}")
    key, raw_value = line.split(":", 1)
    key = key.strip()
    entries.append((key, parse_value(raw_value)))

canonical_source = {key: value for key, value in entries if key != "_version_hash"}
canonical = json.dumps(canonical_source, sort_keys=True, separators=(",", ":"), ensure_ascii=False)
version_hash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()
ordered = [(key, value) for key, value in entries if key != "_version_hash"]
ordered.append(("_version_hash", version_hash))

def emit_value(value):
    if value is None:
        return "null"
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return str(value)
    return json.dumps(value, ensure_ascii=False)

frontmatter_output = "\n".join(f"{key}: {emit_value(value)}" for key, value in ordered)
target_path.write_text(f"---\n{frontmatter_output}\n---\n{body}", encoding="utf-8")
PY

cp "$prepared_file" "$tmp_file"

if mv "$tmp_file" "$target_file"; then
  committed=1
  rm -f "$bak_file"
  exit 0
fi

if [ "$had_original" -eq 1 ] && [ -e "$bak_file" ]; then
  cp "$bak_file" "$target_file"
fi

printf 'write-state: failed to promote %s\n' "$target_file" >&2
exit 1
