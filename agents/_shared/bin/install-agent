#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -ne 1 ]; then
  printf 'usage: install-agent <agent-name>\n' >&2
  exit 64
fi

agent_name="$1"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
shared_dir="$(cd "$script_dir/.." && pwd)"
agents_root="$(cd "$shared_dir/.." && pwd)"
template="$shared_dir/hooks/settings.json.tmpl"
agent_dir="$agents_root/$agent_name"
settings_dir="$agent_dir/.claude"
settings_file="$settings_dir/settings.json"
work_dir="$(mktemp -d "$shared_dir/state/install-agent.XXXXXX")"
rendered="$work_dir/settings.json"

cleanup() {
  rm -rf "$work_dir"
}
trap cleanup EXIT

if [ ! -f "$template" ]; then
  printf 'install-agent: missing template %s\n' "$template" >&2
  exit 66
fi

mkdir -p "$settings_dir"

python3 - "$template" "$agent_name" "$rendered" <<'PY'
import sys
from pathlib import Path

template = Path(sys.argv[1]).read_text(encoding="utf-8")
agent_name = sys.argv[2]
Path(sys.argv[3]).write_text(template.replace("{{AGENT_NAME}}", agent_name), encoding="utf-8")
PY

if [ -f "$settings_file" ] && cmp -s "$rendered" "$settings_file"; then
  chmod 0644 "$settings_file"
  exit 0
fi

mv "$rendered" "$settings_file"
chmod 0644 "$settings_file"
