{"openapi":"3.1.0","info":{"title":"seller-chat-agent","version":"0.1.0"},"paths":{"/v2/conversations":{"post":{"tags":["v2-conversations"],"summary":"Create Conversation","description":"Create a new empty conversation.\n\nThis endpoint:\n1. Generates a unique conversation ID\n2. Creates an empty conversation with no history\n3. Stores the conversation in the database\n4. Returns the conversation ID\n\nThe conversation can then be used with:\n- GET /v2/conversations/{conversation_id} to retrieve it\n- POST /v2/conversations/{conversation_id}/messages to add messages","operationId":"create_conversation_v2_conversations_post","parameters":[{"name":"read_only","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Read Only"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/V2CreateConversationRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/V2CreateConversationResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v2/conversations/{conversation_id}/messages":{"post":{"tags":["v2-conversations"],"summary":"Create Message","description":"Add a message to an existing conversation and stream the response.\n\nThis endpoint:\n1. Verifies the conversation exists\n2. Loads the existing conversation history\n3. Streams the response from GenAI as SSE events\n4. Updates the stored conversation history after streaming completes\n5. Returns streaming response with text tokens, sources, and completion signal","operationId":"create_message_v2_conversations__conversation_id__messages_post","parameters":[{"name":"conversation_id","in":"path","required":true,"schema":{"type":"string","title":"Conversation Id"}},{"name":"read_only","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Read Only"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/V2CreateMessageRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v2/conversations/{conversation_id}":{"get":{"tags":["v2-conversations"],"summary":"Get Conversation","description":"Get a conversation with full history.\n\nThis endpoint:\n1. Loads the conversation from the database\n2. Formats the history for API response\n3. Returns the conversation with full history","operationId":"get_conversation_v2_conversations__conversation_id__get","parameters":[{"name":"conversation_id","in":"path","required":true,"schema":{"type":"string","title":"Conversation Id"}},{"name":"read_only","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Read Only"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/V2GetConversationResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v2/admin/check-admin":{"get":{"tags":["admin"],"summary":"Check Admin Live","operationId":"check_admin_live_v2_admin_check_admin_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Check Admin Live V2 Admin Check Admin Get"}}}}}}},"/v2/admin/conversations/csv":{"get":{"tags":["admin"],"summary":"Get Conversations Csv","description":"Export all V2 conversations from database to CSV format","operationId":"get_conversations_csv_v2_admin_conversations_csv_get","parameters":[{"name":"read_only","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Read Only"}},{"name":"startDate","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Startdate"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"V2CreateConversationRequest":{"properties":{"username":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Username","description":"Username for the conversation"}},"type":"object","title":"V2CreateConversationRequest","description":"Request to create an empty conversation","example":{"username":"seller@example.com"}},"V2CreateConversationResponse":{"properties":{"id":{"type":"string","title":"Id","description":"Conversation ID"}},"type":"object","required":["id"],"title":"V2CreateConversationResponse","description":"Response from creating a conversation","example":{"id":"8711f89d-15ab-477d-ac66-da224286083c"}},"V2CreateMessageRequest":{"properties":{"content":{"type":"string","title":"Content","description":"Message content"}},"type":"object","required":["content"],"title":"V2CreateMessageRequest","description":"Request to create a message in a conversation","example":{"content":"What is BackFunds?"}},"V2GetConversationResponse":{"properties":{"conversation":{"additionalProperties":true,"type":"object","title":"Conversation","description":"Full conversation data including id, username, and history"}},"type":"object","required":["conversation"],"title":"V2GetConversationResponse","description":"Response from getting a conversation with full history","example":{"conversation":{"history":[{"content":"What is BackFunds?","role":"user"},{"content":"BackFunds is a service launched in 2021...","role":"model"}],"id":"conv_123abc","username":"seller@example.com"}}},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"},"input":{"title":"Input"},"ctx":{"type":"object","title":"Context"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}